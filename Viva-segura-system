#include <stdio.h>   // Biblioteca para entrada e saída (printf, scanf)


int main() {

    int opcao; // Variável que guarda a opção escolhida no menu

    // ===== DADOS DO USUÁRIO =====
    char nome[50];          // Nome completo
    char nascimento[20];   // Data de nascimento
    char sangue[10];       // Tipo sanguíneo
    char alergias[100];    // Alergias
    char endereco[100];    // Endereço

    // ===== CONTATO DE EMERGÊNCIA =====
    char nomeContato[50];     
    char telefoneContato[20];

    // Loop principal (repete até o usuário escolher sair)
    do {

        // ===== MENU DO SISTEMA =====
        printf("\n====================================================\n");
        printf("              VIVA SEGURA SYSTEM\n");
        printf("====================================================\n");
        printf(" [1] Cadastro\n");
        printf(" [2] Denuncia\n");
        printf(" [3] Emergencia\n");
        printf(" [4] Monitoramento\n");
        printf(" [5] Ligacao de Seguranca\n");
        printf(" [6] Mapa de Risco\n");
        printf(" [7] Check-in Virtual\n");
        printf(" [8] Medida Protetiva\n");
        printf(" [9] Apoio Psicologico\n");
        printf(" [10] Apoio Juridico\n");
        printf(" [11] Servicos (Rede de Apoio)\n");
        printf(" [12] Telefones de Emergencia\n");
        printf(" [0] Sair\n");
        printf("====================================================\n");

        // Lê a opção digitada pelo usuário
        printf("Escolha uma opcao: ");
        scanf("%d", &opcao);

        getchar(); // Limpa o ENTER que ficou no buffer

        printf("\n----------------------------------------------------\n");

        // ===== ESTRUTURA DE DECISÃO =====
        // Executa um bloco de código dependendo da opção escolhida
        switch (opcao) {

            // ===== CADASTRO =====
            case 1:
                printf("CADASTRO COMPLETO\n");

                // Coleta dados do usuário
                printf("Nome completo: ");
                scanf(" %[^\n]", nome);

                printf("Data de nascimento: ");
                scanf(" %[^\n]", nascimento);

                printf("Tipo sanguineo: ");
                scanf("%s", sangue);

                printf("Alergias: ");
                scanf(" %[^\n]", alergias);

                printf("Endereco: ");
                scanf(" %[^\n]", endereco);

                // Coleta contato de emergência
                printf("\n--- CONTATO DE EMERGENCIA ---\n");

                printf("Nome do contato: ");
                scanf(" %[^\n]", nomeContato);

                printf("Telefone: ");
                scanf("%s", telefoneContato);

                printf("\nCadastro realizado com sucesso!\n");
                break; // Encerra o case

            // ===== DENÚNCIA =====
            case 2:
                // Simula registro de denúncia
                printf("Denuncia registrada!\n");
                printf("Sua identidade esta protegida.\n");
                break;

            // ===== EMERGÊNCIA =====
            case 3:
                // Simula acionamento de emergência
                printf("Palavra-chave acionada com sucesso!\n");
                printf("EMERGENCIA ATIVADA!!\n\n");

                printf("Localizacao enviada para:\n");
                printf("- Policia\n- Ambulancia\n- Contato de emergencia\n\n");

                // Usa o nome cadastrado
                printf("Mensagem enviada:\n");
                printf("\"A mulher %s esta em perigo de vida.\n", nome);
                printf("Favor ir imediatamente ao local indicado.\n");
                printf("Situacao de alto risco.\"\n\n");

                printf("Gravacao iniciada (enviada a cada 15s)\n");

                printf("ORIENTACOES:\n");
                printf("- Procure um local seguro\n");
                printf("- Evite confronto\n");
                break;

            // ===== MONITORAMENTO =====
            case 4:
                // Simula envio de localização em tempo real
                printf("Sistema de monitoramento ativado\n\n");

                printf("Localizacao sendo enviada em tempo real\n");
                printf("Gravacao ativa\n\n");

                printf("Mensagem enviada:\n");
                printf("\"A mulher %s se sente insegura.\"\n", nome);
                break;

            // ===== LIGAÇÃO DE SEGURANÇA =====
            case 5:
                // Simula ligação para apoio
                printf("LIGACAO DE SEGURANCA\n");

                printf("Escolha um contato para ligar:\n");
                printf("[1] Atendimento de seguranca (24h)\n");
                printf("[2] Central de apoio\n");
                printf("[3] Contato de emergencia\n");
                break;

            // ===== MAPA DE RISCO =====
            case 6:
                // Mostra alertas do local
                printf("MAPA DE RISCO\n");

                printf("AREA DE RISCO DETECTADA!\n");

                printf("- Assaltos frequentes\n");
                printf("- Pouca iluminacao\n");

                printf("Sugestao: escolha outra rota\n");
                break;

            // ===== CHECK-IN =====
            case 7:
                // Envia localização automaticamente
                printf("CHECK-IN VIRTUAL\n");

                printf("Localizacao enviada automaticamente\n");
                printf("Status: ATIVO\n");
                break;

            // ===== MEDIDA PROTETIVA =====
            case 8:
                // Alerta de proximidade do agressor
                printf("ALERTA: O agressor se aproximou!\n");

                printf("Localizacao enviada para a policia\n");
                break;

            // ===== APOIO PSICOLÓGICO =====
            case 9:
                // Informações de apoio emocional
                printf("APOIO PSICOLOGICO\n");

                printf("Voce nao esta sozinha.\n");
                printf("CVV: 188\n");
                break;

            // ===== APOIO JURÍDICO =====
            case 10:
                // Informações legais
                printf("APOIO JURIDICO\n");

                printf("Lei Maria da Penha\n");
                printf("Medidas protetivas\n");
                break;

            // ===== SERVIÇOS =====
            case 11:
                // Rede de apoio
                printf("REDE DE APOIO\n");

                printf("Casas abrigo disponiveis\n");
                break;

            // ===== TELEFONES =====
            case 12:
                // Telefones importantes
                printf("TELEFONES IMPORTANTES\n");

                printf("180 - Central da Mulher\n");
                printf("190 - Policia\n");
                printf("192 - SAMU\n");
                printf("193 - Bombeiros\n");
                break;

            // ===== SAIR =====
            case 0:
                // Finaliza o programa
                printf("Encerrando sistema...\n");
                break;

            // ===== ERRO =====
            default:
                // Caso o usuário digite opção inválida
                printf("Opcao invalida!\n");
        }

        // Pausa antes de voltar ao menu
        if (opcao != 0) {
            printf("\nPressione ENTER para continuar...");
            getchar();
        }

    } while (opcao != 0); // Repete enquanto não for 0

    return 0; // Fim do programa
}
