#include <stdio.h>   // Biblioteca para entrada e saída (printf, scanf)
#include <string.h>  // Biblioteca para manipulação de strings (strcmp, strcpy, strchr)
#include <stdlib.h>  // Biblioteca para funções do sistema (system)

// ===== STRUCT =====
// Estrutura que representa um usuário completo (tipo um registro de banco de dados)
struct Usuario {
    char nome[50];              // Nome do usuário
    char nascimento[20];        // Data de nascimento
    char cpf[20];               // CPF

    char email[50];             // Email (login)
    char senha[20];             // Senha
    char telefone[20];          // Telefone

    char endereco[100];         // Endereço
    char cidade[50];            // Cidade

    char sangue[5];             // Tipo sanguíneo
    char alergias[100];         // Alergias

    char contatoNome1[50];      // Nome contato emergência 1
    char contatoTelefone1[20];  // Telefone contato 1

    char contatoNome2[50];      // Nome contato emergência 2
    char contatoTelefone2[20];  // Telefone contato 2

    int contatoCheckin;         // Qual contato será usado no check-in
    int intervaloCheckin;       // Intervalo de envio
    char mensagemCheckin[100];  // Mensagem automática

    int protecaoCheckin;        // Define se precisa senha
    char senhaCheckin[20];      // Senha do check-in
};

// Variável global (acessível em todo o programa)
struct Usuario user;

// Variáveis de controle
int logado = 0;      // 0 = não logado | 1 = logado
int cadastrado = 0;  // 0 = não cadastrado | 1 = cadastrado

// ===== EMAIL =====
// Função que valida se existe '@' no email
int validarEmail(char email[]) {
    return strchr(email, '@') != NULL; // retorna verdadeiro se encontrar '@'
}

// ===== CADASTRO =====
void cadastro() {
    char confirmarSenha[20]; // usada para comparar senha

    system("cls"); // limpa tela

    printf("========================================\n");
    printf("        CADASTRO DE USUARIO\n");
    printf("========================================\n");

    printf("\n--- DADOS PESSOAIS ---\n");

    printf("Nome: ");
    scanf(" %[^\n]", user.nome); // lê com espaço

    printf("Nascimento: ");
    scanf(" %[^\n]", user.nascimento);

    printf("CPF: ");
    scanf("%s", user.cpf);

    printf("\n--- CONTA ---\n");

    // DO-WHILE -> repete até o email ser válido
    do {
        printf("Email: ");
        scanf("%s", user.email);

        if (!validarEmail(user.email)) // valida email
            printf("Email invalido!\n");

    } while (!validarEmail(user.email));

    printf("Senha: ");
    scanf("%s", user.senha);

    printf("Confirmar senha: ");
    scanf("%s", confirmarSenha);

    // strcmp compara strings
    if (strcmp(user.senha, confirmarSenha) != 0) {
        printf("\nErro: senhas nao coincidem!\n\n");
        system("pause");
        return; // sai da função
    }

    printf("Telefone: ");
    scanf("%s", user.telefone);

    printf("\n--- ENDERECO ---\n");

    printf("Endereco: ");
    scanf(" %[^\n]", user.endereco);

    printf("Cidade: ");
    scanf(" %[^\n]", user.cidade);

    printf("\n--- SAUDE ---\n");

    printf("Tipo sanguineo: ");
    scanf("%s", user.sangue);

    printf("Alergias: ");
    scanf(" %[^\n]", user.alergias);

    printf("\n--- CONTATOS DE EMERGENCIA ---\n");

    printf("Nome do Contato 1: ");
    scanf(" %[^\n]", user.contatoNome1);

    printf("Telefone: ");
    scanf("%s\n", user.contatoTelefone1); // cuidado com \n

    printf("Nome do Contato 2: ");
    scanf(" %[^\n]", user.contatoNome2);

    printf("Telefone: ");
    scanf("%s", user.contatoTelefone2);

    printf("\n--- CONFIGURACAO DE SEGURANCA ---\n");
    printf("Proteger check-in com senha?\n1 - Sim\n0 - Nao\n");
    scanf("%d", &user.protecaoCheckin);

    if (user.protecaoCheckin == 1) {
        printf("Crie uma senha: ");
        scanf("%s", user.senhaCheckin);
    }

    printf("\nCadastro realizado com sucesso!\n\n");
    cadastrado = 1;

    system("pause");
}

// ===== LOGIN =====
void login() {
    if (!cadastrado) {
        printf("\nNenhum usuario cadastrado!\n\n");
        system("pause");
        return;
    }

    char email[50], senha[20];

    printf("\n===== LOGIN =====\n");

    printf("Email: ");
    scanf("%s", email);

    printf("Senha: ");
    scanf("%s", senha);

    if (strcmp(email, user.email) == 0 && strcmp(senha, user.senha) == 0) {
        logado = 1; // usuário autenticado
        printf("\nLogin realizado com sucesso!\n\n");
    } else {
        printf("\nErro: email ou senha incorretos!\n\n");
    }

    system("pause");
}

// ===== VER DADOS =====
void verDados() {
    if (!logado) {
        printf("\nFaca login primeiro!\n\n");
        system("pause");
        return;
    }

    printf("\n========== DADOS DO USUARIO ==========\n");

    printf("Nome: %s\n", user.nome);
    printf("Nascimento: %s\n", user.nascimento);
    printf("CPF: %s\n", user.cpf);
    printf("Email: %s\n", user.email);
    printf("Telefone: %s\n", user.telefone);
    printf("Endereco: %s\n", user.endereco);
    printf("Cidade: %s\n", user.cidade);
    printf("Tipo sanguineo: %s\n", user.sangue);
    printf("Alergias: %s\n", user.alergias);

    printf("\nContatos:\n");
    printf("- %s (%s)\n", user.contatoNome1, user.contatoTelefone1);
    printf("- %s (%s)\n", user.contatoNome2, user.contatoTelefone2);

    system("pause");
}

// ===== EMERGENCIA =====
void emergencia() {
    if (!logado) {
        printf("\nFaca login primeiro!\n\n");
        system("pause");
        return;
    }

    system("cls");

    printf("========================================\n");
    printf("        EMERGENCIA ACIONADA\n");
    printf("========================================\n");

   // ===== POLICIA =====
    printf("\n--- POLICIA [190] ---\n");
    printf("URGENTE: A mulher %s corre risco de vida!\n", user.nome);
    printf("Favor se dirigir imediatamente para a localizacao enviada.\n");

    // ===== CONTATOS =====
    printf("\n--- CONTATOS DE EMERGENCIA ---\n");
    printf("%s pode estar em perigo de vida!\n", user.nome);
    printf("Acompanhe a localizacao e tente contato imediato.\n");

    printf("\nContatos notificados:\n");
    printf("- %s (%s)\n", user.contatoNome1, user.contatoTelefone1);
    printf("- %s (%s)\n", user.contatoNome2, user.contatoTelefone2);

    printf("\nLocalizacao enviada para a policia [190] e contatos de emergencia.\n");
    printf("Ajuda a caminho!\n\n");

    system("pause");
}

// ===== MONITORAMENTO =====
void monitoramento() {
    if (!logado) {
        printf("\nFaca login primeiro!\n\n");
        system("pause");
        return;
    }

     printf("========================================\n");
    printf("        MONITORAMENTO ATIVO\n");
    printf("========================================\n");

    printf("\nSistema vibrando...\n");
    printf("Enviando localizacao em tempo real...\n");

    // ===== POLICIA =====
    printf("\n--- POLICIA [190] ---\n");
    printf("Atencao: A mulher %s se sente insegura neste local.\n", user.nome);
    printf("Favor realizar patrulhamento e verificar a situacao.\n");

    // ===== CONTATOS =====
    printf("\n--- CONTATOS DE EMERGENCIA ---\n");
    printf("%s nao se sente bem neste local.\n", user.nome);
    printf("Por favor, entre em contato ou va ate a localizacao enviada.\n");

    printf("\nContatos notificados:\n");
    printf("- %s (%s)\n", user.contatoNome1, user.contatoTelefone1);
    printf("- %s (%s)\n", user.contatoNome2, user.contatoTelefone2);

    printf("\nLocalizacao enviada para a policia [190] e contatos de emergencia.\n\n");
    system("pause");
}

// ===== CHECK-IN =====
void checkin() {
    if (!logado) {
        printf("\nFaca login primeiro!\n\n");
        system("pause");
        return;
    }

    int op;

    printf("========================================\n");
    printf("             CHECK-IN\n");
    printf("========================================\n");

    printf("\n1 - Ativar\n");
    printf("2 - Desativar\n");
    printf("3 - Configurar\n");
    printf("4 - Status\n");

    printf("\nEscolha: ");
    scanf("%d", &op);

    // SWITCH controla as opções do usuário
    switch(op) {

        // ATIVAR check-in
        case 1:
            printf("\nCheck-in ativado!\n");
            printf("A localizacao sera enviada automaticamente.\n");
            break;

        // DESATIVAR check-in
        case 2:
            if (user.protecaoCheckin == 1) {
                char senha[20];
                printf("\nDigite a senha: ");
                scanf("%s", senha);

                if (strcmp(senha, user.senhaCheckin) == 0)
                    printf("\nCheck-in desativado com sucesso!\n");
                else
                    printf("\nSenha incorreta! Nao foi possivel desativar.\n");
            } else {
                printf("\nCheck-in desativado!\n");
            }
            break;

        // CONFIGURAR check-in
        case 3:
            printf("\n===== CONFIGURACAO =====\n");

            printf("Escolha o contato (1 ou 2): ");
            scanf("%d", &user.contatoCheckin);

            printf("Intervalo de envio (em minutos): ");
            scanf("%d", &user.intervaloCheckin);

            printf("Mensagem que sera enviada:\n");
            scanf(" %[^\n]", user.mensagemCheckin);

            printf("\nConfiguracao salva com sucesso!\n");
            break;

        // STATUS do check-in
        case 4:
            printf("\n===== STATUS DO CHECK-IN =====\n");

            printf("Contato selecionado: %d\n", user.contatoCheckin);
            printf("Intervalo: %d minutos\n", user.intervaloCheckin);
            printf("Mensagem: %s\n", user.mensagemCheckin);

            if (user.protecaoCheckin == 1)
                printf("Protecao: Ativada\n");
            else
                printf("Protecao: Desativada\n");
            break;

        default:
            printf("\nOpcao invalida!\n");
    }
    system("pause");
}

// ===== DENUNCIA =====
void denuncia() {

   int anonimo;       // 1 = anônimo, 0 = identificado
   char texto[200];   // descrição da denúncia
    
    system("cls");
     
    printf("========================================\n");
    printf("            DENUNCIA\n");
    printf("========================================\n");

    printf("\nDescreva a situacao:\n");
    scanf(" %[^\n]", texto); // lê texto completo

    printf("\nDeseja enviar anonimamente?\n");
    printf("1 - Sim\n");
    printf("0 - Nao\n");
    printf("Escolha: ");
    scanf("%d", &anonimo);

    printf("\nEnviando denuncia...\n\n");
    system("pause");

    system("cls");
     
    printf("\n========================================\n");
    printf("        CONFIRMACAO DA DENUNCIA\n");
    printf("========================================\n");

    // IF define tipo de denúncia
    if (anonimo == 1) {
        printf("Tipo: Anonima\n");
        printf("Sua identidade foi protegida.\n");
    } else {
        printf("Tipo: Identificada\n");
        printf("Responsavel: %s\n", user.nome);
    }

    printf("\n--- DESCRICAO DA DENUNCIA ---\n");
    printf("%s\n", texto);

    printf("\nSua denuncia foi enviada com sucesso!\n\n");
    printf("As autoridades competentes foram notificadas.\n\n");

    strcpy(texto, ""); // limpa o conteúdo da variável
    
    system("pause");
}

// ===== TELEFONES =====
void telefones() {
    printf("\n========= TELEFONES IMPORTANTES ========\n\n");
    
    printf("190 - Policia\n");
    printf("192 - SAMU\n");
    printf("193 - Bombeiros\n");
    printf("180 - Central da Mulher\n\n");

    system("pause");
}

// ===== MENU =====
void menu() {
    system("cls");

    printf("========================================\n");
    printf("        SISTEMA VIVA SEGURA\n");
    printf("========================================\n");

    printf("\n[1] Cadastro\n");
    printf("[2] Login\n");
    printf("[3] Ver dados\n");
    printf("[4] Emergencia\n");
    printf("[5] Monitoramento\n");
    printf("[6] Check-in\n");
    printf("[7] Denuncia\n");
    printf("[8] Telefones\n");

    printf("\n[0] Sair\n");
    printf("========================================\n");

    printf("Escolha: ");
}

// ===== MAIN =====
int main() {
    int op;

    // Loop principal do sistema
    do {
        menu();
        scanf("%d", &op);

        // SWITCH controla navegação do menu
        switch(op) {
            case 1: cadastro(); break;
            case 2: login(); break;
            case 3: verDados(); break;
            case 4: emergencia(); break;
            case 5: monitoramento(); break;
            case 6: checkin(); break;
            case 7: denuncia(); break;
            case 8: telefones(); break;
        }

    } while(op != 0); // sai quando usuário digita 0

    return 0;
}
